# Firebase Configuration
# Make sure firebase-service-account.json is in the root of the backend directory.

# Application
APP_NAME=Deepfake Authentication Gateway
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Security
JWT_AUDIENCE=authenticated
JWT_ALGORITHM=HS256

# File Upload
MAX_FILE_SIZE=5368709120
ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.webm,.mkv,.wav,.mp3,.flac,.ogg,.png,.jpg,.jpeg,.gif,.webp,.bmp

# Scanning
SCAN_TIMEOUT=300
THREAT_THRESHOLD_LOW=30.0
THREAT_THRESHOLD_HIGH=70.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_ENABLED=true

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
