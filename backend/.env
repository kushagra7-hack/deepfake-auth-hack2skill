# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# Database
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Application
APP_NAME=Deepfake Authentication Gateway
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Security
JWT_AUDIENCE=authenticated
JWT_ALGORITHM=HS256

# File Upload
MAX_FILE_SIZE=5368709120
ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.webm,.mkv,.wav,.mp3,.flac,.ogg,.png,.jpg,.jpeg,.gif,.webp,.bmp

# Scanning
SCAN_TIMEOUT=300
THREAT_THRESHOLD_LOW=30.0
THREAT_THRESHOLD_HIGH=70.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
